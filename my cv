<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Muhammad Noman — Senior UI/UX Designer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0E0F12;
    --paper: #F5F2ED;
    --cream: #EDE9E1;
    --accent: #C8602A;
    --accent2: #2A6BC8;
    --muted: #7A7570;
    --border: rgba(14,15,18,0.10);
    --ff-head: 'Syne', sans-serif;
    --ff-body: 'DM Sans', sans-serif;
    --ff-mono: 'DM Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  ::selection { background: var(--accent); color: white; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--ff-body);
    background: var(--paper);
    color: var(--ink);
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9999;
    mix-blend-mode: multiply;
  }
  .cursor-dot {
    width: 8px; height: 8px; background: var(--accent);
    border-radius: 50%; position: absolute; transform: translate(-50%,-50%);
    transition: transform 0.1s ease;
  }
  .cursor-ring {
    width: 36px; height: 36px; border: 1.5px solid var(--accent);
    border-radius: 50%; position: absolute; transform: translate(-50%,-50%);
    transition: width 0.3s ease, height 0.3s ease, transform 0.15s ease;
  }
  body:has(a:hover) .cursor-ring,
  body:has(button:hover) .cursor-ring { width: 56px; height: 56px; }

  /* Noise texture overlay */
  body::before {
    content: '';
    position: fixed; inset: 0; pointer-events: none; z-index: 1000;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 48px;
    background: rgba(245,242,237,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    transition: padding 0.3s ease;
  }
  nav.scrolled { padding: 14px 48px; }
  .nav-logo {
    font-family: var(--ff-head); font-size: 18px; font-weight: 800;
    letter-spacing: -0.03em; text-decoration: none; color: var(--ink);
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    font-family: var(--ff-mono); font-size: 12px; letter-spacing: 0.06em;
    text-transform: uppercase; text-decoration: none; color: var(--muted);
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: -2px; left: 0;
    width: 0; height: 1px; background: var(--accent); transition: width 0.25s ease;
  }
  .nav-links a:hover { color: var(--ink); }
  .nav-links a:hover::after { width: 100%; }
  .nav-cta {
    font-family: var(--ff-mono); font-size: 12px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 10px 20px;
    border: 1px solid var(--ink); background: none; color: var(--ink);
    cursor: none; transition: all 0.2s;
    text-decoration: none;
  }
  .nav-cta:hover { background: var(--ink); color: var(--paper); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 120px 48px 60px;
    position: relative; overflow: hidden;
  }
  .hero-bg-text {
    position: absolute; right: -20px; top: 50%; transform: translateY(-50%);
    font-family: var(--ff-head); font-size: clamp(120px, 18vw, 240px);
    font-weight: 800; color: transparent;
    -webkit-text-stroke: 1px rgba(14,15,18,0.06);
    line-height: 1; pointer-events: none; user-select: none;
    letter-spacing: -0.05em;
  }
  .hero-left { position: relative; z-index: 2; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--accent);
    border: 1px solid rgba(200,96,42,0.3); padding: 6px 14px;
    margin-bottom: 28px;
  }
  .hero-tag::before { content: '●'; font-size: 7px; animation: blink 2s step-end infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  .hero-name {
    font-family: var(--ff-head); font-size: clamp(52px, 7vw, 88px);
    font-weight: 800; line-height: 0.95; letter-spacing: -0.04em;
    margin-bottom: 24px;
    opacity: 0; animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-name .line2 { color: var(--accent); display: block; }

  .hero-title {
    font-size: 18px; font-weight: 300; color: var(--muted);
    margin-bottom: 40px; line-height: 1.6;
    opacity: 0; animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero-title strong { color: var(--ink); font-weight: 500; }

  .hero-stats {
    display: flex; gap: 36px; margin-bottom: 48px;
    opacity: 0; animation: fadeUp 0.8s 0.5s forwards;
  }
  .stat-item { }
  .stat-num {
    font-family: var(--ff-head); font-size: 36px; font-weight: 800;
    letter-spacing: -0.04em; color: var(--ink); line-height: 1;
  }
  .stat-num span { color: var(--accent); }
  .stat-label {
    font-family: var(--ff-mono); font-size: 10px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--muted); margin-top: 4px;
  }

  .hero-actions {
    display: flex; gap: 14px;
    opacity: 0; animation: fadeUp 0.8s 0.6s forwards;
  }
  .btn-primary {
    font-family: var(--ff-mono); font-size: 12px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 14px 28px;
    background: var(--ink); color: var(--paper);
    border: none; cursor: none; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s;
  }
  .btn-primary:hover { background: var(--accent); }
  .btn-secondary {
    font-family: var(--ff-mono); font-size: 12px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 14px 28px;
    background: none; color: var(--ink);
    border: 1px solid var(--ink); cursor: none; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s;
  }
  .btn-secondary:hover { background: var(--ink); color: var(--paper); }

  .hero-right {
    display: flex; justify-content: flex-end; align-items: center;
    position: relative; z-index: 2;
    opacity: 0; animation: fadeIn 1s 0.3s forwards;
  }
  .avatar-wrapper { position: relative; }
  .avatar-frame {
    width: 340px; height: 420px; position: relative; overflow: hidden;
  }
  .avatar-frame img {
    width: 100%; height: 100%; object-fit: cover; object-position: top;
    filter: grayscale(20%);
  }
  .avatar-frame::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(200,96,42,0.15));
  }
  .avatar-border {
    position: absolute; top: 20px; left: 20px; right: -20px; bottom: -20px;
    border: 1.5px solid var(--accent); z-index: -1;
  }
  .avatar-tag {
    position: absolute; bottom: 28px; left: -28px;
    background: var(--ink); color: var(--paper);
    padding: 14px 20px;
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.06em;
  }
  .avatar-tag .tag-num {
    font-family: var(--ff-head); font-size: 28px; font-weight: 800;
    color: var(--accent); display: block; line-height: 1;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
  }

  /* ─── SECTION COMMON ─── */
  section { padding: 100px 48px; }
  .section-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 60px; padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .section-label {
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 10px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before { content: ''; width: 28px; height: 1px; background: var(--accent); }
  .section-title {
    font-family: var(--ff-head); font-size: clamp(36px, 5vw, 56px);
    font-weight: 800; letter-spacing: -0.04em; line-height: 1;
  }

  /* ─── ABOUT ─── */
  .about { background: var(--cream); }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1.6fr; gap: 80px; align-items: start;
  }
  .about-intro {
    font-size: 20px; font-weight: 300; line-height: 1.7; color: var(--ink);
    margin-bottom: 32px;
  }
  .about-intro strong { font-weight: 600; }
  .about-quote {
    border-left: 3px solid var(--accent); padding-left: 20px;
    font-family: var(--ff-head); font-size: 22px; font-weight: 600;
    letter-spacing: -0.02em; color: var(--muted); margin: 32px 0;
    font-style: italic;
  }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 32px; }
  .contact-item {
    display: flex; flex-direction: column; gap: 3px;
    padding: 16px; border: 1px solid var(--border); background: var(--paper);
    transition: border-color 0.2s;
  }
  .contact-item:hover { border-color: var(--accent); }
  .contact-item-label { font-family: var(--ff-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
  .contact-item-val { font-size: 13px; font-weight: 500; color: var(--ink); word-break: break-all; }
  .contact-item-val a { color: var(--ink); text-decoration: none; }
  .contact-item-val a:hover { color: var(--accent); }

  /* ─── SKILLS ─── */
  .skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .skill-card {
    background: var(--paper); padding: 32px 28px;
    border: 1px solid var(--border);
    transition: all 0.25s ease; position: relative; overflow: hidden;
  }
  .skill-card::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--accent); transform: scaleY(0); transform-origin: bottom;
    transition: transform 0.25s ease;
  }
  .skill-card:hover { background: var(--cream); }
  .skill-card:hover::before { transform: scaleY(1); }
  .skill-icon { font-size: 28px; margin-bottom: 16px; }
  .skill-name { font-family: var(--ff-head); font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
  .skill-tag {
    font-family: var(--ff-mono); font-size: 10px; letter-spacing: 0.05em;
    padding: 4px 10px; border: 1px solid var(--border);
    color: var(--muted); transition: all 0.2s;
  }
  .skill-card:hover .skill-tag { border-color: rgba(200,96,42,0.3); color: var(--ink); }

  /* ─── EXPERIENCE ─── */
  .experience { background: var(--ink); color: var(--paper); }
  .experience .section-title { color: var(--paper); }
  .experience .section-label { color: rgba(200,96,42,0.9); }
  .experience .section-label::before { background: rgba(200,96,42,0.9); }
  .experience .section-header { border-bottom-color: rgba(255,255,255,0.1); }
  .exp-timeline { position: relative; }
  .exp-timeline::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 1px; background: rgba(255,255,255,0.1);
  }
  .exp-item {
    display: grid; grid-template-columns: 220px 1fr; gap: 48px;
    padding: 48px 0 48px 32px; border-bottom: 1px solid rgba(255,255,255,0.08);
    position: relative;
  }
  .exp-item::before {
    content: ''; position: absolute; left: -4px; top: 60px;
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent); border: 2px solid var(--ink);
  }
  .exp-item:last-child { border-bottom: none; }
  .exp-meta { }
  .exp-period {
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.06em;
    color: var(--accent); margin-bottom: 8px;
  }
  .exp-company {
    font-family: var(--ff-head); font-size: 22px; font-weight: 700;
    color: var(--paper); margin-bottom: 4px; letter-spacing: -0.02em;
  }
  .exp-location {
    font-family: var(--ff-mono); font-size: 11px; color: rgba(255,255,255,0.35);
    margin-top: 6px;
  }
  .exp-current {
    display: inline-block; font-family: var(--ff-mono); font-size: 9px;
    letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px;
    background: rgba(200,96,42,0.2); color: var(--accent); margin-top: 10px;
  }
  .exp-role {
    font-family: var(--ff-head); font-size: 18px; font-weight: 600;
    color: rgba(255,255,255,0.9); margin-bottom: 20px; letter-spacing: -0.02em;
  }
  .exp-points { list-style: none; display: flex; flex-direction: column; gap: 14px; }
  .exp-points li {
    font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.65);
    line-height: 1.65; padding-left: 20px; position: relative;
    transition: color 0.2s;
  }
  .exp-points li::before {
    content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 12px;
  }
  .exp-points li strong { color: var(--paper); font-weight: 500; }
  .exp-item:hover .exp-points li { color: rgba(255,255,255,0.8); }

  /* ─── EDUCATION ─── */
  .edu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .edu-card {
    padding: 36px; border: 1px solid var(--border);
    transition: all 0.25s; position: relative; overflow: hidden;
  }
  .edu-card::after {
    content: attr(data-year); position: absolute; right: -10px; bottom: -20px;
    font-family: var(--ff-head); font-size: 80px; font-weight: 800;
    color: transparent; -webkit-text-stroke: 1px rgba(14,15,18,0.07);
    line-height: 1; pointer-events: none;
  }
  .edu-card:hover { border-color: var(--accent); background: var(--cream); }
  .edu-period {
    font-family: var(--ff-mono); font-size: 11px; color: var(--accent);
    letter-spacing: 0.06em; margin-bottom: 12px;
  }
  .edu-degree { font-family: var(--ff-head); font-size: 20px; font-weight: 700; margin-bottom: 6px; letter-spacing: -0.02em; }
  .edu-school { font-size: 14px; color: var(--muted); }
  .edu-icon { font-size: 32px; margin-bottom: 20px; }

  /* ─── TOOLS ─── */
  .tools { background: var(--cream); }
  .tools-marquee {
    overflow: hidden; margin-bottom: 20px;
  }
  .tools-track {
    display: flex; gap: 24px; width: max-content;
    animation: marquee 20s linear infinite;
  }
  .tools-track2 { animation-direction: reverse; animation-duration: 25s; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .tool-pill {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 20px; border: 1px solid var(--border); background: var(--paper);
    font-family: var(--ff-mono); font-size: 12px; white-space: nowrap;
    transition: all 0.2s;
  }
  .tool-pill:hover { border-color: var(--accent); background: rgba(200,96,42,0.05); }

  /* ─── LANGUAGE ─── */
  .lang-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .lang-card {
    padding: 28px; border: 1px solid var(--border); background: var(--paper);
    transition: all 0.2s;
  }
  .lang-card:hover { border-color: var(--accent); }
  .lang-name { font-family: var(--ff-head); font-size: 20px; font-weight: 700; margin-bottom: 6px; }
  .lang-level { font-family: var(--ff-mono); font-size: 11px; color: var(--accent); margin-bottom: 16px; }
  .lang-bar { height: 3px; background: var(--border); border-radius: 2px; margin-top: 4px; }
  .lang-fill { height: 100%; border-radius: 2px; background: var(--accent); }
  .lang-skills { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 16px; }
  .lang-skill { }
  .lang-skill-name { font-family: var(--ff-mono); font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 5px; }

  /* ─── CONTACT CTA ─── */
  .cta-section {
    background: var(--ink); color: var(--paper);
    text-align: center; padding: 120px 48px;
  }
  .cta-label { font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 24px; }
  .cta-title {
    font-family: var(--ff-head); font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -0.04em; line-height: 1; margin-bottom: 20px;
  }
  .cta-title .accent { color: var(--accent); }
  .cta-sub { font-size: 18px; font-weight: 300; color: rgba(255,255,255,0.5); margin-bottom: 48px; }
  .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-light {
    font-family: var(--ff-mono); font-size: 12px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 16px 32px;
    background: var(--paper); color: var(--ink); border: none; cursor: none;
    text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s;
  }
  .btn-light:hover { background: var(--accent); color: var(--paper); }
  .btn-outline-light {
    font-family: var(--ff-mono); font-size: 12px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 16px 32px;
    background: none; color: var(--paper); border: 1px solid rgba(255,255,255,0.2);
    cursor: none; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s;
  }
  .btn-outline-light:hover { border-color: var(--accent); color: var(--accent); }

  /* ─── FOOTER ─── */
  footer {
    padding: 28px 48px; border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-name { font-family: var(--ff-head); font-size: 16px; font-weight: 800; letter-spacing: -0.02em; }
  .footer-name span { color: var(--accent); }
  .footer-copy { font-family: var(--ff-mono); font-size: 11px; color: var(--muted); }

  /* ─── SCROLL REVEAL ─── */
  .reveal {
    opacity: 0; transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; padding: 100px 24px 40px; }
    .hero-right { display: none; }
    section { padding: 60px 24px; }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .skills-grid { grid-template-columns: 1fr; }
    .exp-item { grid-template-columns: 1fr; gap: 12px; padding-left: 24px; }
    .edu-grid { grid-template-columns: 1fr; }
    .lang-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: 24px; }
    .contact-grid { grid-template-columns: 1fr; }
    .footer { flex-direction: column; gap: 12px; text-align: center; }
  }

  /* Tab highlight for nav */
  .nav-links a.active { color: var(--ink); }
  .nav-links a.active::after { width: 100%; }
</style>
</head>
<body>

<!-- Custom cursor -->
<div class="cursor">
  <div class="cursor-dot" id="cursorDot"></div>
  <div class="cursor-ring" id="cursorRing"></div>
</div>

<!-- Nav -->
<nav id="navbar">
  <a href="#" class="nav-logo">MN<span>.</span></a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#education">Education</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="mailto:muhammadnommankhan@gmail.com" class="nav-cta">Hire Me →</a>
</nav>

<!-- Hero -->
<section class="hero" id="home">
  <div class="hero-bg-text">UX</div>
  <div class="hero-left">
    <div class="hero-tag">Available for Projects</div>
    <h1 class="hero-name">
      Muhammad<br>
      <span class="line2">Noman</span>
    </h1>
    <p class="hero-title">
      <strong>Senior UI/UX Designer</strong> with 5+ years crafting<br>
      digital experiences that blend aesthetics with function.
    </p>
    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-num">5<span>+</span></div>
        <div class="stat-label">Years Exp.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">30<span>+</span></div>
        <div class="stat-label">Projects</div>
